import urllib.request
import json
import os
import sys
from config import settings  # To load the key from .env

# Reconfigure stdout to support printing UTF-8 emojis on Windows
if sys.platform.startswith('win'):
    sys.stdout.reconfigure(encoding='utf-8')


# Set up the prompt and parameters
model = "llama3.2"  # Locally pulled model
prompt = "Explain quantum computing in one sentence."

print(f"Sending request to Local Ollama using model: {model}...")

# Build request
req = urllib.request.Request(
    "http://localhost:11434/v1/chat/completions",
    headers={
        "Authorization": "Bearer ollama", 
        "Content-Type": "application/json"
    },
    data=json.dumps({
        "model": model,
        "messages": [{"role": "user", "content": prompt}],
        "max_tokens": 100
    }).encode("utf-8"),
    method="POST"
)

try:
    with urllib.request.urlopen(req, timeout=30) as res:
        response_data = json.loads(res.read().decode())
        message_content = response_data["choices"][0]["message"]["content"]
        print("\n[Local Ollama Response]:")
        print(message_content)
except Exception as e:
    print(f"\nRequest failed. Error: {e}")

