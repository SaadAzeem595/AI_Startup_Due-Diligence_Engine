import urllib.request
import json

# Define your locally pulled Ollama model (e.g., 'llama3.2', 'mistral', 'phi3')
model = "llama3.2"  
prompt = "Explain quantum computing in one sentence."

print(f"Sending request to Local Ollama using model: {model}...")

# Ollama's OpenAI endpoint expects standard OpenAI payload layout
payload = {
    "model": model,
    "messages": [{"role": "user", "content": prompt}],
    "stream": False  # Crucial: stops Ollama from sending raw token fragments
}

# The OpenAI compatibility endpoint hosted natively by your local Ollama app
url = "http://localhost:11434/v1/chat/completions"

req = urllib.request.Request(
    url,
    headers={"Content-Type": "application/json"},
    data=json.dumps(payload).encode("utf-8"),
    method="POST"
)

try:
    with urllib.request.urlopen(req, timeout=30) as res:
        response_data = json.loads(res.read().decode())
        
        # Because Ollama mimics OpenAI completely, the parsing paths are identical!
        message_content = response_data["choices"][0]["message"]["content"]
        
        print("\n[Ollama Response]:")
        print(message_content.strip())
except Exception as e:
    print(f"\nRequest failed. Error: {e}")